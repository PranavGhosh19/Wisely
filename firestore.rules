rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // 🔹 USERS
    // =========================
    match /users/{userId} {

      // User can only access their own profile
      allow create: if request.auth != null 
        && request.auth.uid == userId;

      allow read, update, delete: if request.auth != null 
        && request.auth.uid == userId;

      // =========================
      // 🔹 PERSONAL EXPENSES
      // =========================
      match /personalExpenses/{expenseId} {

        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.createdById == request.auth.uid
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;

        allow read: if request.auth != null
          && request.auth.uid == userId;

        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.createdById;
      }
    }

    // =========================
    // 🔹 GROUPS
    // =========================
    match /groups/{groupId} {

      // Any logged-in user can read groups
      allow read: if request.auth != null;

      // Only creator can create group
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;

      // Only members can update/delete group
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      // =========================
      // 🔹 GROUP EXPENSES
      // =========================
      match /expenses/{expenseId} {

        // CREATE
        allow create: if request.auth != null
          && request.resource.data.createdById == request.auth.uid
          && request.auth.uid in request.resource.data.groupMemberIds
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;

        // READ
        allow read: if request.auth != null
          && request.auth.uid in resource.data.groupMemberIds;

        // UPDATE / DELETE
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.createdById;
      }
    }
  }
}