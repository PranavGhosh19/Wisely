
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // 🔹 COLLECTION GROUP: EXPENSES
    // =========================
    // Must be at the top level for collectionGroup("expenses") queries to be authorized.
    // Authorized if the user is explicitly listed in the denormalized groupMemberIds array.
    match /{path=**}/expenses/{expenseId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.groupMemberIds;
    }

    // =========================
    // 🔹 USERS
    // =========================
    match /users/{userId} {
      allow create: if request.auth != null 
        && request.auth.uid == userId;

      allow read, update, delete: if request.auth != null 
        && request.auth.uid == userId;

      // Personal expenses subcollection
      match /personalExpenses/{expenseId} {
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.createdById == request.auth.uid;

        allow read: if request.auth != null
          && request.auth.uid == userId;

        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.createdById;
      }
    }

    // =========================
    // 🔹 GROUPS
    // =========================
    match /groups/{groupId} {

      // ✅ Only members can read group metadata
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;

      // ✅ Create group (creator must be in the initial members list)
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // ✅ Only members can update/delete
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Group expenses subcollection
      match /expenses/{expenseId} {
        // Direct collection query read access (also covered by collection group rule)
        allow read: if request.auth != null
          && request.auth.uid in resource.data.groupMemberIds;

        allow create: if request.auth != null
          && request.resource.data.createdById == request.auth.uid
          && request.auth.uid in request.resource.data.groupMemberIds;

        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.createdById;
      }
    }
  }
}
