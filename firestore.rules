rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // 🔹 USERS
    // =========================
    match /users/{userId} {
      allow create: if request.auth != null 
        && request.auth.uid == userId;

      allow read, update, delete: if request.auth != null 
        && request.auth.uid == userId;

      match /personalExpenses/{expenseId} {
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.createdById == request.auth.uid;

        allow read: if request.auth.uid == userId;

        allow update, delete: if request.auth.uid == resource.data.createdById;
      }
    }

    // =========================
    // 🔹 GROUPS
    // =========================
    match /groups/{groupId} {

      // Helper to check membership
      function isMember() {
        return request.auth != null && request.auth.uid in resource.data.members;
      }

      // Helper to check membership from subcollection (fetches parent)
      function isMemberOfParent() {
        return request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }

      // ✅ Allow any authenticated user to 'get' (single doc read) so they can see group name for joining
      // ✅ But only members can 'list' groups or see internal details
      allow get: if request.auth != null;
      allow list: if isMember();

      // ✅ Create group
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // ✅ Only members can update/delete
      // Added permission for any authenticated user to 'update' only the 'members' field if they are adding themselves
      // (Though in production you'd use a more restrictive rule, for MVP this works with current app logic)
      allow update: if isMember() || (request.auth != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']));
      allow delete: if isMember();

      // =========================
      // 🔹 GROUP EXPENSES
      // =========================
      match /expenses/{expenseId} {

        // ✅ Create expense if user is member of the parent group
        allow create: if request.auth != null
          && request.resource.data.createdById == request.auth.uid
          && isMemberOfParent();

        // ✅ Read expense ONLY if user is member of the parent group
        allow read: if isMemberOfParent();

        // ✅ Update/Delete only by creator
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.createdById;
      }
    }
  }
}