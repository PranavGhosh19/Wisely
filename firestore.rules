rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // 🔹 HELPERS
    // =========================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check if user is a member of the group document
    function isMemberOfGroup(groupId) {
      return isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    // =========================
    // 🔹 USERS
    // =========================
    match /users/{userId} {
      // Allow any authenticated user to read profiles for collaboration (selecting "Paid By")
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isOwner(userId);

      // Personal expenses subcollection
      match /personalExpenses/{expenseId} {
        allow read, write: if isOwner(userId);
      }
    }

    // =========================
    // 🔹 GROUPS
    // =========================
    match /groups/{groupId} {
      // Allow authenticated users to read group metadata (necessary for joining and selection)
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated()
        && request.resource.data.get('createdBy', '') == request.auth.uid
        && request.auth.uid in request.resource.data.get('members', []);

      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.get('members', [])
        || (
          // Controlled self-join: Only one user added, and it's the requester
          request.resource.data.get('members', []).size() == resource.data.get('members', []).size() + 1
          && request.auth.uid in request.resource.data.get('members', [])
        )
      );

      allow delete: if isAuthenticated() && request.auth.uid in resource.data.get('members', []);

      // Group expenses subcollection
      match /expenses/{expenseId} {
        // Use the groupMemberIds field on the expense for faster permission checks,
        // or check membership on the parent group for scoped collection queries.
        allow read: if isAuthenticated() && (
          request.auth.uid in resource.data.get('groupMemberIds', []) || isMemberOfGroup(groupId)
        );
        
        allow create: if isAuthenticated() && (
          request.auth.uid in request.resource.data.get('groupMemberIds', []) || isMemberOfGroup(groupId)
        );
        
        allow update: if isAuthenticated() && (
          request.auth.uid in resource.data.get('groupMemberIds', []) || isMemberOfGroup(groupId)
        );
        
        allow delete: if isAuthenticated() && (
          request.auth.uid in resource.data.get('groupMemberIds', []) || isMemberOfGroup(groupId)
        );
      }
    }

    // =========================
    // 🔹 COLLECTION GROUP: EXPENSES
    // =========================
    match /{path=**}/expenses/{expenseId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.get('groupMemberIds', []);
    }
  }
}