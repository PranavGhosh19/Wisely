{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Essential user profile data stored in Firestore.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "groupIds": { "type": "array", "items": { "type": "string" } },
        "categories": { "type": "array", "items": { "type": "string" } },
        "fcmTokens": { "type": "array", "items": { "type": "string" }, "description": "Device tokens for FCM push notifications." },
        "currency": { "type": "string", "enum": ["AED", "AFN", "ALL", "AMD", "ANG", "AOA", "ARS", "AUD", "AWG", "AZN", "BAM", "BBD", "BDT", "BGN", "BHD", "BIF", "BMD", "BND", "BOB", "BRL", "BSD", "BTN", "BWP", "BYN", "BZD", "CAD", "CDF", "CHF", "CLP", "CNY", "COP", "CRC", "CUP", "CVE", "CZK", "DJF", "DKK", "DOP", "DZD", "EGP", "ERN", "ETB", "EUR", "FJD", "FKP", "GBP", "GEL", "GHS", "GIP", "GMD", "GNF", "GTQ", "GYD", "HKD", "HNL", "HRK", "HTG", "HUF", "IDR", "ILS", "INR", "IQD", "IRR", "ISK", "JMD", "JOD", "JPY", "KES", "KGS", "KHR", "KMF", "KPW", "KRW", "KWD", "KYD", "KZT", "LAK", "LBP", "LKR", "LRD", "LSL", "LYD", "MAD", "MDL", "MGA", "MKD", "MMK", "MNT", "MOP", "MRU", "MUR", "MVR", "MWK", "MXN", "MYR", "MZN", "NAD", "NGN", "NIO", "NOK", "NPR", "NZD", "OMR", "PAB", "PEN", "PGK", "PHP", "PKR", "PLN", "PYG", "QAR", "RON", "RSD", "RUB", "RWF", "SAR", "SBD", "SCR", "SDG", "SEK", "SGD", "SHP", "SLL", "SOS", "SRD", "SSP", "STN", "SYP", "SZL", "THB", "TJS", "TMT", "TND", "TOP", "TRY", "TTD", "TWD", "TZS", "UAH", "UGX", "USD", "UYU", "UZS", "VES", "VND", "VUV", "WST", "XAF", "XCD", "XOF", "XPF", "YER", "ZAR", "ZMW", "ZWL"], "default": "USD" },
        "isSmartSettleEnabled": { "type": "boolean", "description": "User preference for optimized settlement view." }
      },
      "required": ["uid", "name", "email"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A record of a personal or group expense.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["PERSONAL", "GROUP"] },
        "date": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdById": { "type": "string" },
        "updatedBy": { "type": "string" },
        "updatedById": { "type": "string" },
        "deletedBy": { "type": "string" },
        "deletedById": { "type": "string" },
        "paidBy": { "type": "string" },
        "notes": { "type": "string" },
        "groupId": { "type": "string" },
        "groupMemberIds": { "type": "array", "items": { "type": "string" } },
        "isDeleted": { "type": "boolean" },
        "receiptUrl": { "type": "string" },
        "receiptName": { "type": "string" },
        "isSettled": { "type": "boolean" },
        "splitType": { "type": "string" },
        "splitBetween": { "type": "array", "items": { "type": "object" } }
      }
    },
    "Group": {
      "title": "Group",
      "description": "A group for shared expense tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" },
        "groupBalances": { "type": "object", "description": "Cached net balances for each user." },
        "settlements": { "type": "array", "items": { "type": "object" }, "description": "Simplified debts/transfers needed to zero out." },
        "isSmartSettleEnabled": { "type": "boolean", "description": "Group preference for optimized settlement view." }
      }
    }
  },
  "auth": {
    "providers": ["email/password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Group metadata."
    },
    "/groups/{groupId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Group shared expenses."
    },
    "/users/{userId}/personalExpenses/{expenseId}": {
      "schema": "Expense",
      "description": "Private personal expenses."
    }
  }
}