
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Essential user profile data stored in Firestore.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "groupIds": { "type": "array", "items": { "type": "string" } },
        "categories": { "type": "array", "items": { "type": "string" } },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "INR"], "default": "USD" }
      },
      "required": ["uid", "name", "email"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A record of a personal or group expense.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["PERSONAL", "GROUP"] },
        "date": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdById": { "type": "string" },
        "updatedBy": { "type": "string" },
        "updatedById": { "type": "string" },
        "deletedBy": { "type": "string" },
        "deletedById": { "type": "string" },
        "paidBy": { "type": "string" },
        "notes": { "type": "string" },
        "groupId": { "type": "string" },
        "groupMemberIds": { "type": "array", "items": { "type": "string" } },
        "isDeleted": { "type": "boolean" },
        "receiptUrl": { "type": "string" },
        "receiptName": { "type": "string" }
      }
    },
    "Group": {
      "title": "Group",
      "description": "A group for shared expense tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email/password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Group metadata."
    },
    "/groups/{groupId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Group shared expenses."
    },
    "/users/{userId}/personalExpenses/{expenseId}": {
      "schema": "Expense",
      "description": "Private personal expenses."
    }
  }
}
